<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import java.net.URL?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sfp.folha.ui.ParametrosController" styleClass="root">
    
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
    </padding>

    <ImageView fitWidth="60" fitHeight="60" preserveRatio="true">
        <image>
            <Image url="@gato.png" />
        </image>
    </ImageView>

    <Label text="Atualização de Parâmetros Legais (INSS)" styleClass="title-label" />

    <VBox spacing="15.0" styleClass="form-container">
        
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Piso (R$):" styleClass="field-label" prefWidth="160"/>
            <TextField fx:id="inputPiso" promptText="Ex: 0.00" styleClass="input-field" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Teto (R$):" styleClass="field-label" prefWidth="160"/>
            <TextField fx:id="inputTeto" promptText="Ex: 1621.00" styleClass="input-field" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Alíquota (Decimal):" styleClass="field-label" prefWidth="160"/>
            <TextField fx:id="inputAliquota" promptText="Ex: 0.075" styleClass="input-field" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Parcela a Deduzir (R$):" styleClass="field-label" prefWidth="160"/>
            <TextField fx:id="inputParcelaDeduzir" promptText="Ex: 0.00" styleClass="input-field" HBox.hgrow="ALWAYS"/>
        </HBox>

    </VBox>

    <Button text="SALVAR FAIXA INSS" onAction="#salvarFaixa" styleClass="primary-button" />

    <Label fx:id="labelMensagem" text="" styleClass="result-value-green" />

</VBox>

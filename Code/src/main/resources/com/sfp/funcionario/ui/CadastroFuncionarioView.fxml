<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import java.net.URL?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sfp.funcionario.ui.CadastroFuncionarioController" styleClass="root">
    
    <stylesheets>
        <URL value="@/com/sfp/core/ui/style.css" />
    </stylesheets>

    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
    </padding>

    <ImageView fitWidth="80" fitHeight="80" preserveRatio="true">
        <image>
            <Image url="/com/sfp/core/ui/gato.png" />
        </image>
    </ImageView>

    <Label text="Cadastro de Funcionário" styleClass="title-label" />

    <VBox spacing="15.0" styleClass="form-container">
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Nome Completo:" styleClass="field-label" prefWidth="150"/>
            <TextField fx:id="inputNome" promptText="Ex: João da Silva" styleClass="input-field" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="CPF:" styleClass="field-label" prefWidth="150"/>
            <TextField fx:id="inputCpf" promptText="Ex: 123.456.789-00" styleClass="input-field" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Cargo:" styleClass="field-label" prefWidth="150"/>
            <TextField fx:id="inputCargo" promptText="Ex: Analista de Sistemas" styleClass="input-field" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Salário Bruto (R$):" styleClass="field-label" prefWidth="150"/>
            <TextField fx:id="inputSalario" promptText="Ex: 5000.00" styleClass="input-field" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Data de Admissão:" styleClass="field-label" prefWidth="150"/>
            <DatePicker fx:id="inputDataAdmissao" promptText="Selecione a data" styleClass="input-field" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        </HBox>

        <HBox fx:id="boxStatus" alignment="CENTER_LEFT" spacing="10.0" visible="false" managed="false">
            <Label text="Status:" styleClass="field-label" prefWidth="150"/>
            <CheckBox fx:id="checkStatus" text="Funcionário Ativo" selected="true" style="-fx-text-fill: white;"/>
        </HBox>
    </VBox>

    <Button text="Salvar" onAction="#salvarFuncionario" styleClass="primary-button" />

    <Label fx:id="labelMensagem" text="" styleClass="result-value-green" />

</VBox>

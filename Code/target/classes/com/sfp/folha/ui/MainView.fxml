<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import java.net.URL?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sfp.folha.ui.MainController" styleClass="root">
    
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
    </padding>

    <!-- Logo do Projeto -->
    <ImageView fitWidth="120" fitHeight="120" preserveRatio="true">
        <image>
            <Image url="@gato.png" />
        </image>
    </ImageView>

    <Label text="Motor de Cálculo SFP" styleClass="title-label" />

    <VBox spacing="15.0" styleClass="form-container">
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Salário Base (R$):" styleClass="field-label" prefWidth="150"/>
            <TextField fx:id="inputSalario" promptText="Ex: 1518.00" styleClass="input-field" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Horas Extras (50%):" styleClass="field-label" prefWidth="150"/>
            <TextField fx:id="inputHoras50" promptText="Ex: 10" styleClass="input-field" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Horas Extras (100%):" styleClass="field-label" prefWidth="150"/>
            <TextField fx:id="inputHoras100" promptText="Ex: 0" styleClass="input-field" HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>

    <Button text="PROCESSAR FOLHA" onAction="#calcularFolha" styleClass="primary-button" />

    <VBox alignment="CENTER_LEFT" spacing="10.0" styleClass="result-container">
        <HBox spacing="10.0">
            <Label text="Total de Proventos: " styleClass="result-label-title"/>
            <Label fx:id="labelProventos" text="R$ 0.00" styleClass="result-value-green"/>
        </HBox>
        <HBox spacing="10.0">
            <Label text="Total de Descontos: " styleClass="result-label-title"/>
            <Label fx:id="labelDescontos" text="R$ 0.00" styleClass="result-value-red"/>
        </HBox>
        <HBox spacing="10.0" styleClass="divider-top">
            <Label text="Salário Líquido Final: " styleClass="result-label-title-large"/>
            <Label fx:id="labelLiquido" text="R$ 0.00" styleClass="result-value-large"/>
        </HBox>
    </VBox>
</VBox>

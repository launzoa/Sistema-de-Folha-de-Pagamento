<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sfp.folha.ui.FormEndereco" styleClass="conteudo" spacing="20" alignment="CENTER">

    <stylesheets>
        <URL value="@style.css"/>
    </stylesheets>

    <Label fx:id="labelTitulo" text="Cadastrar Endereço" styleClass="card_title"/>

    <TextField fx:id="txtCep" promptText="CEP" styleClass="historico_field" prefWidth="360"/>
    <TextField fx:id="txtLogradouro" promptText="Logradouro" styleClass="historico_field" prefWidth="360"/>
    <TextField fx:id="txtBairro" promptText="Bairro" styleClass="historico_field" prefWidth="360"/>
    <TextField fx:id="txtComplemento" promptText="Complemento" styleClass="historico_field" prefWidth="360"/>

    <HBox alignment="CENTER" spacing="15">
        <Button text="Salvar" onAction="#salvar" styleClass="primary-button"/>
        <Button text="Cancelar" onAction="#cancelar" styleClass="secondary-button"/>
    </HBox>

</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.sfp.folha.ui.TelaParametro" styleClass="conteudo" spacing="20">
    <stylesheets>
        <URL value="@style.css"/>
    </stylesheets>
    
    <HBox spacing="15" alignment="CENTER_LEFT" styleClass="card_dash">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Selecione a Empresa para Vincular os Parâmetros:" styleClass="holerite-section-title"/>
            <ComboBox fx:id="comboEmpresasParam" promptText="Escolha uma empresa..." styleClass="combo_box" maxWidth="Infinity"/>
        </VBox>
        
        <Button text="+ Adicionar Parâmetro" styleClass="primary-button" />
        <Button text="Editar Parâmetro" styleClass="primary-button" />
        
    </HBox>    
    
    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <Label text="Vigência Atual" styleClass="holerite-section-title"/>
            
        <GridPane styleClass="holerite-dados" hgap="20" vgap="6">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <Label text="Alíquota INSS (%):" styleClass="holerite-field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Label text="Horas Mensais Padrão:" styleClass="holerite-field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label fx:id="labelAliquota" text="—" styleClass="holerite-field-value"  GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Label fx:id="labelHorasMensais" text="—" styleClass="holerite-field-value"  GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Cesta Básica (R$):" styleClass="holerite-field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <Label text="Salário Mínimo (R$):" styleClass="holerite-field-label" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label fx:id="labelCestaBasica" text="—" styleClass="holerite-field-value"  GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <Label fx:id="labelSalarioMinimo" text="—" styleClass="holerite-field-value"  GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        </GridPane>
    </VBox>

    <!-- TABELA -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <Label text="Histórico de Parâmetros da Empresa" styleClass="holerite-section-title" HBox.hgrow="ALWAYS"/>
        <TableView fx:id="tabelaParametro" styleClass="tabela_dash" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colAnoVigencia" text="Ano/Vigência" prefWidth="120"/>
                <TableColumn fx:id="colAliquotaTab" text="Alíquot INSS" prefWidth="130"/>
                <TableColumn fx:id="colHorasTab" text="Hrs Mensais" prefWidth="120"/>
                <TableColumn fx:id="colCestaTab" text="Cesta Básica" prefWidth="130"/>
                <TableColumn fx:id="colSalarioTab" text="Salário Mínimo" prefWidth="140"/>
            </columns>
        </TableView>
    </VBox>




</VBox>
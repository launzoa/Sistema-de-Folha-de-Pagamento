<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.sfp.folha.ui.FormEmpresa" styleClass="conteudo" spacing="20" alignment="CENTER">
    <stylesheets>
        <URL value="@style.css"/>
    </stylesheets>

    <Label fx:id="labelTitulo" text="Cadastrar Empresa" styleClass="card_title"/>

    <TextField fx:id="txtCnpj" promptText="CNPJ" styleClass="historico_field" prefWidth="420"/>
    <TextField fx:id="txtRazaoSocial" promptText="Razão Social" styleClass="historico_field" prefWidth="420"/>
    <TextField fx:id="txtEmail" promptText="Email" styleClass="historico_field" prefWidth="420"/>
    <TextField fx:id="txtRespLegal" promptText="Responsável Legal" styleClass="historico_field" prefWidth="420"/>

    <TextField fx:id="txtAliquotaFGTS" promptText="Alíquota FGTS" styleClass="historico_field" prefWidth="420"/>
    <TextField fx:id="txtHorasMensais" promptText="Horas Mensais" styleClass="historico_field" prefWidth="420"/>
    <TextField fx:id="txtValCestaBasic" promptText="Valor Cesta Básica" styleClass="historico_field" prefWidth="420"/>
    <TextField fx:id="txtPercHoraExtra50" promptText="Percentual Hora Extra 50" styleClass="historico_field" prefWidth="420"/>
    <TextField fx:id="txtPercHoraExtra100" promptText="Percentual Hora Extra 100" styleClass="historico_field" prefWidth="420"/>

    <HBox alignment="CENTER" spacing="15">
        <Button text="Salvar" onAction="#salvar" styleClass="primary-button"/>
        <Button text="Cancelar" onAction="#cancelar" styleClass="secondary-button"/>
    </HBox>

</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.sfp.folha.ui.TelaDashboard" styleClass="conteudo" spacing="20">
    <stylesheets>
        <URL value="@style.css"/>
    </stylesheets>
    
    <HBox spacing="20">
       <!-- Card Competência -->
        <VBox styleClass="card_dash" HBox.hgrow="ALWAYS">
            <Label text="Competência" styleClass="card_title"/>
            <Label fx:id="labelCompetencia" text="mes/ano" styleClass="card_label"/>
        </VBox>
        
        <!-- Card Funcionários --> 
        <VBox styleClass="card_dash" HBox.hgrow="ALWAYS">
            <Label text="Funcionários ativos" styleClass="card_title"/>
            <Label fx:id="labelFuncionarios" text="num_funcioonarios" styleClass="card_label"/>
        </VBox>
        
        <!-- Card Status -->
        <VBox styleClass="card_dash" HBox.hgrow="ALWAYS">
            <Label text="Status da folha" styleClass="card_title"/>
            <Label fx:id="labelStatus" text="Aberta/Fechada" styleClass="card_label"/>
        </VBox>
    </HBox>

    <!-- TABELAS -->
    <HBox VBox.vgrow="ALWAYS">
        
        <!-- Tabela Folha do Mês -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
            <Label text="Folha do mês/ano **atual" styleClass="card_title"/>
            <TableView fx:id="tabelaFolha" VBox.vgrow="ALWAYS" styleClass="tabela_dash">
                <columns>
                    <TableColumn text="Nome" prefWidth="120"/>
                    <TableColumn text="Cargo" prefWidth="100"/>
                    <TableColumn text="Salário" prefWidth="100"/>
                    <TableColumn text="Status" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
        
        <!-- Tabela Provisões -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
            <Label text="Provisões Trabalhistas" styleClass="card_title"/>
            <TableView fx:id="tabelaProvisoes" VBox.vgrow="ALWAYS" styleClass="tabela_dash">
                <columns>
                    <TableColumn text="Provisão" prefWidth="150"/>
                    <TableColumn text="Total" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>

</VBox>

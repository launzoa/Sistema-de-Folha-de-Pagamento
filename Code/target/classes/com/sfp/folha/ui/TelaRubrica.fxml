<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.sfp.folha.ui.TelaRubrica" styleClass="conteudo" spacing="20">
    <stylesheets>
        <URL value="@style.css"/>
    </stylesheets>
    
    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="card_dash">
        
        <VBox spacing="5">
            <Label text="Filtrar por Código:" styleClass="holerite-section-title"/>
            <TextField fx:id="txtCodigo" promptText="Digite o código..." prefWidth="200" styleClass="historico_field"/>
        </VBox>
        
        <Region HBox.hgrow="ALWAYS"/>
        
        <VBox alignment="BOTTOM_LEFT">
            <HBox spacing="10">
                <Button text="Buscar" styleClass="primary-button" onAction="#buscar"/>
                <Button text="Limpar Filtros" styleClass="secondary-button" onAction="#limparFiltros"/>
            </HBox>
        </VBox>
    </HBox>
    <!-- BOTÃO DO TOPO -->
    <HBox spacing="20" alignment="CENTER_RIGHT">
        <Button text="+ Nova Rubrica" styleClass="primary-button" onAction="#addRubrica"/>
        <Button text="Editar Rubrica" styleClass="primary-button" onAction="#editarRubrica"/>
    </HBox>

    <!-- TABELA -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <TableView fx:id="tabelaRubrica" styleClass="tabela_dash" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCod" text="Código" prefWidth="70"/>
                <TableColumn fx:id="colDescr" text="Descrição" prefWidth="150"/>
                <TableColumn fx:id="colNat" text="Natureza" prefWidth="120"/>
                <TableColumn fx:id="colTipo" text="Tipo" prefWidth="100"/>
                <TableColumn fx:id="colIncINSS" text="Inc. INSS" prefWidth="70"/>
                <TableColumn fx:id="colIncFGTS" text="Inc. FGTS" prefWidth="70"/>
                <TableColumn fx:id="colIncIRRF" text="Inc. IRRF" prefWidth="70"/>
                <TableColumn fx:id="colPadrao" text="Padrão" prefWidth="70"/>
                <TableColumn fx:id="colAtivo" text="Ativo" prefWidth="70"/>
            </columns>
        </TableView>
    </VBox>


</VBox>

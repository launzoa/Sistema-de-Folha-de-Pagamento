<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.sfp.folha.ui.TelaHolerite" styleClass="conteudo" spacing="20">
    <stylesheets>
        <URL value="@style.css"/>
    </stylesheets>

    <!-- Seleção de Funcionário e Competência -->
    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="card_dash">
        <Label text="Funcionário: " styleClass="lancamento-field"/>
        <ComboBox fx:id="comboFuncionario" promptText="Selecione..." prefWidth="200" styleClass="combo_box"/>

        <Label text="Competência:" styleClass="lancamento-field"/>
        <ComboBox fx:id="comboCompetencia" promptText="Mês/Ano" prefWidth="150" styleClass="combo_box"/>

        <Button text="Visualizar" styleClass="primary-button" onAction="#visualizar"/>
        <Button text="Imprimir" styleClass="secondary-button" onAction="#imprimir"/>
    </HBox>

    <!-- Corpo do Holerite -->
    <VBox fx:id="painelHolerite" styleClass="holerite-container" spacing="0">

        <!-- Cabeçalho Empresa -->
        <VBox styleClass="holerite-header" spacing="4">
            <Label fx:id="labelEmpresa" text="EMPRESA MODELO S.A." styleClass="holerite-empresa"/>
            <HBox spacing="20">
                <Label text="CNPJ: " styleClass="holerite-empresa-info"/>
                <Label fx:id="labelCNPJEmp" text="00.000.000/0001-00" styleClass="holerite-empresa-info"/>
                <Label text="|  Endereço: " styleClass="holerite-empresa-info"/>
                <Label fx:id="labelEndEMp" text="Prudente" styleClass="holerite-empresa-info"/>
            </HBox>
            
        </VBox>

        <!-- Dados do Funcionário -->
        <GridPane styleClass="holerite-dados" hgap="20" vgap="6">
            <columnConstraints>
                <ColumnConstraints percentWidth="30"/>
                <ColumnConstraints percentWidth="30"/>
                <ColumnConstraints percentWidth="40"/>
            </columnConstraints>

            <Label text="Nome:"       styleClass="holerite-field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Label text="CPF:"        styleClass="holerite-field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <Label text="Cargo:"      styleClass="holerite-field-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>

            <Label fx:id="labelNome"  text="—" styleClass="holerite-field-value" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Label fx:id="labelCpf"   text="—" styleClass="holerite-field-value" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <Label fx:id="labelCargo" text="—" styleClass="holerite-field-value" GridPane.columnIndex="2" GridPane.rowIndex="1"/>

            <Label text="Admissão:"     styleClass="holerite-field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <Label text="Banco/Conta:"  styleClass="holerite-field-label" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            <Label text="Dependentes:"  styleClass="holerite-field-label" GridPane.columnIndex="2" GridPane.rowIndex="2"/>

            <Label fx:id="labelAdmissao"    text="—" styleClass="holerite-field-value" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <Label fx:id="labelBanco"        text="—" styleClass="holerite-field-value" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
            <Label fx:id="labelDependentes"  text="—" styleClass="holerite-field-value" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
        </GridPane>

        <!-- Proventos e Descontos -->
        <HBox spacing="0" VBox.vgrow="ALWAYS">
            <VBox HBox.hgrow="ALWAYS" styleClass="holerite-section">
                <Label text="Proventos:" styleClass="holerite-section-title"/>
                <TableView fx:id="tabelaProventos" styleClass="tabela_dash" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colProvDescricao" text="Descrição" prefWidth="180"/>
                        <TableColumn fx:id="colProvRef"       text="Ref."      prefWidth="60"/>
                        <TableColumn fx:id="colProvValor"     text="Valor"     prefWidth="90"/>
                    </columns>
                </TableView>
            </VBox>

            <Separator orientation="VERTICAL"/>

            <VBox HBox.hgrow="ALWAYS" styleClass="holerite-section">
                <Label text="Descontos:" styleClass="holerite-section-title"/>
                <TableView fx:id="tabelaDescontos" styleClass="tabela_dash" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colDescDescricao" text="Descrição" prefWidth="180"/>
                        <TableColumn fx:id="colDescRef"       text="Ref."      prefWidth="60"/>
                        <TableColumn fx:id="colDescValor"     text="Valor"     prefWidth="90"/>
                    </columns>
                </TableView>
            </VBox>
        </HBox>

        <!-- Rodapé -->
        <GridPane styleClass="holerite-footer" hgap="0">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <HBox GridPane.columnIndex="0" GridPane.rowIndex="0" alignment="CENTER_LEFT"
                  spacing="10" styleClass="holerite-footer-cell">
                <Label text="Total Proventos:" styleClass="holerite-footer-label"/>
                <Label fx:id="labelTotalProventos" text="R$ 0,00" styleClass="holerite-footer-value-green"/>
            </HBox>

            <HBox GridPane.columnIndex="1" GridPane.rowIndex="0" alignment="CENTER_LEFT"
                  spacing="10" styleClass="holerite-footer-cell">
                <Label text="Total Descontos:" styleClass="holerite-footer-label"/>
                <Label fx:id="labelTotalDescontos" text="R$ 0,00" styleClass="holerite-footer-value-red"/>
            </HBox>

            <HBox GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1"
                  alignment="CENTER" styleClass="holerite-footer-liquido">
                <Label text="SALÁRIO LÍQUIDO: " styleClass="holerite-liquido-label"/>
                <Label fx:id="labelLiquido" text="R$ 0,00" styleClass="holerite-liquido-value"/>
            </HBox>
        </GridPane>

    </VBox>

</VBox>

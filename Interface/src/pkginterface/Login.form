              <AuxValues>
                <AuxValue name="JavaCodeGenerator_CreateCodeCustom" type="java.lang.String" value="new javax.swing.JPanel(){&#xa;    @Override&#xa;    protected void paintComponent(java.awt.Graphics g) {&#xa;        super.paintComponent(g);&#xa;        java.awt.Graphics2D g2d = (java.awt.Graphics2D) g;&#xa;&#xa;        // Melhora a qualidade do desenho&#xa;        g2d.setRenderingHint(java.awt.RenderingHints.KEY_ANTIALIASING, java.awt.RenderingHints.VALUE_ANTIALIAS_ON);&#xa;&#xa;        int w = getWidth();&#xa;        int h = getHeight();&#xa;&#xa;        // 1. Definindo as cores da sua paleta (convertendo os Hexadecimais)&#xa;        java.awt.Color indigoImperial = java.awt.Color.decode(&quot;#4b0082&quot;);&#xa;        java.awt.Color roxoMedio = java.awt.Color.decode(&quot;#5c4f68&quot;);&#xa;        java.awt.Color violetaIndigo = java.awt.Color.decode(&quot;#8436a1&quot;);&#xa;        java.awt.Color ametistaSuave = java.awt.Color.decode(&quot;#de70ec&quot;);&#xa;&#xa;        // 2. Definindo a posi&#xe7;&#xe3;o de cada cor (0.0 &#xe9; o topo, 1.0 &#xe9; a base)&#xa;        float[] dist = {0.0f, 0.33f, 0.67f, 1.0f};&#xa;        java.awt.Color[] colors = {indigoImperial, roxoMedio, violetaIndigo, ametistaSuave};&#xa;&#xa;        // 3. Criando o gradiente linear de cima para baixo&#xa;        java.awt.LinearGradientPaint lgp = new java.awt.LinearGradientPaint(&#xa;            new java.awt.geom.Point2D.Float(0, 0),    // Ponto inicial (topo)&#xa;            new java.awt.geom.Point2D.Float(0, h),    // Ponto final (base)&#xa;            dist,&#xa;            colors&#xa;        );&#xa;&#xa;        g2d.setPaint(lgp);&#xa;        g2d.fillRect(0, 0, w, h);&#xa;    }&#xa;}"/>
              </AuxValues>


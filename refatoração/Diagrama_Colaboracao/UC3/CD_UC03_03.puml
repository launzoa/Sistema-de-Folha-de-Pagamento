@startuml
skinparam style strictuml
skinparam linetype ortho
skinparam shadowing false
skinparam defaultTextAlignment center

skinparam nodesep 150
skinparam ranksep 80

skinparam rectangle {
  BackgroundColor #FFFFCC
  BorderColor Black
  RoundCorner 0
}

skinparam actor {
  BorderColor Black
  FontColor Black
}

title CD_UC03_03_ConfirmarAlteracoesEmpresa

actor "Administrador" as Administrador

rectangle ":FormEmpresa.fxml" as FormEmpresaFXML
rectangle ":FormEmpresa" as FormEmpresa
rectangle ":ControladorEmpresa" as ControladorEmpresa
rectangle ":MySQLEmpresaRepository" as MySQLEmpresaRepository
rectangle ":TelaEmpresa" as TelaEmpresa

Administrador -[hidden]down- FormEmpresaFXML
FormEmpresa -[hidden]down- ControladorEmpresa
ControladorEmpresa -[hidden]down- MySQLEmpresaRepository

FormEmpresa -[hidden]left- TelaEmpresa

Administrador ---> FormEmpresaFXML : confirmaAlteracoes() : void

FormEmpresaFXML -right-> FormEmpresa : 1: salvar() : void

FormEmpresa ---> ControladorEmpresa : 1.1: atualizarEmpresa(empresa): void

ControladorEmpresa ---> MySQLEmpresaRepository : 1.1.1: salvarEmpresa(empresa): void \n1.4.1.1: empresa := buscarEmpresaUnica(): Empresa

FormEmpresa ---> FormEmpresa : 1.2: fecharJanela() : void

TelaEmpresa ---> FormEmpresa : 1.3: salvo := isSalvoComSucesso(): boolean

TelaEmpresa ---> TelaEmpresa : 1.4: carregarEmpresa() : void \n1.5: exibirEmpresaSelecionada(): void

TelaEmpresa ---> ControladorEmpresa : 1.4.1: empresa := buscarEmpresa(): Empresa





@enduml
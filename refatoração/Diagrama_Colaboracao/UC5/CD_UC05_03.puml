@startuml
skinparam style strictuml
skinparam linetype ortho
skinparam shadowing false
skinparam defaultTextAlignment center

skinparam nodesep 120
skinparam ranksep 100

skinparam rectangle {
  BackgroundColor #FFFFCC
  BorderColor Black
  RoundCorner 0
}

skinparam actor {
  BorderColor Black
  FontColor Black
}

title CD_UC05_03_EditarUsuario

actor "Administrador" as Administrador

rectangle ":FormUsuario.fxml" as FormUsuarioFXML
rectangle ":FormUsuario" as FormUsuario
rectangle ":ControladorUsuario" as ControladorUsuario
rectangle ":MySQLUsuarioRepository" as MySQLUsuarioRepository
rectangle ":TelaUsuario" as TelaUsuario

Administrador -[hidden]down- FormUsuarioFXML
FormUsuarioFXML -[hidden]right- FormUsuario
FormUsuario -[hidden]down- ControladorUsuario
ControladorUsuario -[hidden]down- MySQLUsuarioRepository

FormUsuario -[hidden]down- TelaUsuario
ControladorUsuario -[hidden]right- TelaUsuario

Administrador ---> FormUsuarioFXML : editaUsuario(nomeUsuario,\nsenha, status) : void

FormUsuarioFXML ---> FormUsuario : 1: salvar() : void

FormUsuario ---> ControladorUsuario : 1.1: atualizarUsuario(id,\nnome, senha, status) : void

ControladorUsuario ---> MySQLUsuarioRepository : 1.1.1: atualizarUsuario(id, nome, senha, status) : void\n1.4.1.1: usuarios := listarUsuarios() : List<Usuario>

FormUsuario ---> FormUsuario : 1.2: fecharJanela() \n: void

TelaUsuario -right-> FormUsuario : 1.3: salvo := isSalvoComSucesso()\n: boolean

TelaUsuario -up-> TelaUsuario : 1.4: atualizarTabela() : void

TelaUsuario ---> ControladorUsuario : 1.4.1: usuarios := listarUsuarios()\n: List<Usuario>

@enduml
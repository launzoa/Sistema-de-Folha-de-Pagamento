<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.sfp.folha.ui.TelaHoleriteController" styleClass="conteudo" spacing="20">
    <stylesheets>
        <URL value="@/com/sfp/core/ui/style.css"/>
    </stylesheets>

    <!-- Header / Controle da Folha -->
    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 15px;">
        <VBox>
            <Label text="Mês de Competência" styleClass="card_title"/>
            <ComboBox fx:id="comboCompetencia" styleClass="combo_box" onAction="#mudarCompetencia"/>
        </VBox>
        <VBox>
            <Label text="Status" styleClass="card_title"/>
            <Label fx:id="labelStatus" text="Buscando..." style="-fx-font-size: 14px; -fx-text-fill: green"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Removido cards estatísticos conforme pedido pelo usuário -->

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        
        <!-- Esquerda: Lista de Funcionários na Folha -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefWidth="400">
            <Label text="Funcionários (Holerites Processados)" styleClass="card_title"/>
            <TableView fx:id="tabelaHolerites" VBox.vgrow="ALWAYS" styleClass="tabela_dash">
                <columns>
                    <TableColumn fx:id="colNome" text="Nome" prefWidth="150"/>
                    <TableColumn fx:id="colCargo" text="Cargo" prefWidth="120"/>
                    <TableColumn fx:id="colLiquido" text="Líquido" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Direita: Pré-visualização do Holerite e Botões -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefWidth="600" spacing="10">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Holerite Eletrônico" styleClass="card_title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Exportar Este" styleClass="secondary-button" onAction="#exportarHoleriteSelecionado"/>
                <Button text="Exportar Todos (Mês)" styleClass="primary-button" onAction="#exportarTodosHolerites"/>
                <Button text="Exportar Relatório Geral" styleClass="primary-button" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" onAction="#exportarRelatorioGeral"/>
            </HBox>
            
            <VBox fx:id="painelHoleritePreview" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-width: 1px; -fx-padding: 15px;" VBox.vgrow="ALWAYS" spacing="10">
                
                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-border-color: transparent transparent #cccccc transparent; -fx-border-width: 0 0 1px 0; -fx-padding: 0 0 10px 0;">
                    <VBox>
                        <Label fx:id="lblPreviewEmpresa" text="-" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                        <Label fx:id="lblPreviewCnpj" text="-" style="-fx-font-size: 11px;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <VBox alignment="CENTER_RIGHT">
                        <Label text="Recibo de Pagamento de Salário" style="-fx-font-weight: bold;"/>
                        <Label fx:id="lblPreviewCompetencia" text="-" style="-fx-font-size: 12px;"/>
                    </VBox>
                </HBox>

                <HBox spacing="10" style="-fx-border-color: transparent transparent #cccccc transparent; -fx-border-width: 0 0 1px 0; -fx-padding: 0 0 10px 0;">
                    <VBox>
                        <Label text="Funcionário:" style="-fx-font-size: 11px; -fx-text-fill: gray;"/>
                        <Label fx:id="lblPreviewFuncionario" text="-" style="-fx-font-weight: bold;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <VBox>
                        <Label text="Cargo:" style="-fx-font-size: 11px; -fx-text-fill: gray;"/>
                        <Label fx:id="lblPreviewCargo" text="-"/>
                    </VBox>
                </HBox>

                <!-- Tabela de Rubricas Interna -->
                <TableView fx:id="tabelaRubricasPreview" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="colRubricaCod" text="Cód" prefWidth="50"/>
                        <TableColumn fx:id="colRubricaDesc" text="Descrição" prefWidth="250"/>
                        <TableColumn fx:id="colRubricaRef" text="Ref" prefWidth="60"/>
                        <TableColumn fx:id="colRubricaProv" text="Proventos" prefWidth="100"/>
                        <TableColumn fx:id="colRubricaDescValor" text="Descontos" prefWidth="100"/>
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="20" style="-fx-border-color: #cccccc transparent transparent transparent; -fx-border-width: 1px 0 0 0; -fx-padding: 10px 0 0 0;">
                    <VBox alignment="CENTER_RIGHT">
                        <Label text="Total Proventos:" style="-fx-font-size: 11px; -fx-text-fill: gray;"/>
                        <Label fx:id="lblPreviewTotalProv" text="R$ 0,00"/>
                    </VBox>
                    <VBox alignment="CENTER_RIGHT">
                        <Label text="Total Descontos:" style="-fx-font-size: 11px; -fx-text-fill: gray;"/>
                        <Label fx:id="lblPreviewTotalDesc" text="R$ 0,00"/>
                    </VBox>
                    <VBox alignment="CENTER_RIGHT">
                        <Label text="Valor Líquido:" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                        <Label fx:id="lblPreviewLiquido" text="R$ 0,00" style="-fx-font-weight: bold;"/>
                    </VBox>
                </HBox>

            </VBox>
        </VBox>

    </HBox>

</VBox>

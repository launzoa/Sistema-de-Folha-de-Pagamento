<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.sfp.empresa.ui.FormEmpresa" styleClass="conteudo" spacing="20" alignment="CENTER">
    <stylesheets>
        <URL value="@../../core/ui/style.css"/>
    </stylesheets>

    <Label fx:id="labelTitulo" text="Cadastrar Empresa" styleClass="card_title"/>

    <VBox spacing="5" alignment="CENTER_LEFT">
        <Label text="CNPJ:" styleClass="label-form"/>
        <TextField fx:id="txtCnpj" promptText="Ex: 00.000.000/0001-00" styleClass="historico_field" prefWidth="420"/>
    </VBox>

    <VBox spacing="5" alignment="CENTER_LEFT">
        <Label text="Razão Social:" styleClass="label-form"/>
        <TextField fx:id="txtRazaoSocial" promptText="Ex: Minha Empresa S.A." styleClass="historico_field" prefWidth="420"/>
    </VBox>

    <VBox spacing="5" alignment="CENTER_LEFT">
        <Label text="E-mail de Contato:" styleClass="label-form"/>
        <TextField fx:id="txtEmail" promptText="Ex: contato@empresa.com.br" styleClass="historico_field" prefWidth="420"/>
    </VBox>

    <VBox spacing="5" alignment="CENTER_LEFT">
        <Label text="Responsável Legal:" styleClass="label-form"/>
        <TextField fx:id="txtRespLegal" promptText="Ex: João da Silva" styleClass="historico_field" prefWidth="420"/>
    </VBox>

    <VBox spacing="5" alignment="CENTER_LEFT">
        <Label text="Dia de Fechamento do Ponto Mensal:" styleClass="label-form"/>
        <ComboBox fx:id="cbDiaFechamentoPonto" styleClass="historico_field" prefWidth="420"/>
    </VBox>


    <HBox alignment="CENTER" spacing="15">
        <Button text="Salvar" onAction="#salvar" styleClass="primary-button"/>
        <Button text="Cancelar" onAction="#cancelar" styleClass="secondary-button"/>
    </HBox>

</VBox>

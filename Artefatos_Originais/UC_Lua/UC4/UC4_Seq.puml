@startuml
title Sequência - UC-04: Cadastro de Usuários do Sistema

actor "Administrador" as Admin
participant ":TelaUsuarios" as UI
participant ":UsuarioController" as Controller
participant "CatalogoUsuarios" as Catalogo
participant "u:Usuario" as Usuario
participant "LogAuditoria" as Log

Admin -> UI : informarDadosUsuario(nomeUsuario, senha, perfil)
activate UI
UI -> Controller : cadastrarUsuario(nomeUsuario, senha, perfil)
activate Controller

Controller -> Catalogo : criarUsuario(nomeUsuario, senha, perfil)
activate Catalogo
Catalogo -> Usuario ** : create(nomeUsuario, senha, perfil)
Catalogo --> Controller : u
deactivate Catalogo

Controller -> Log : registrar(usuario, data, "Cadastro Usuario")
activate Log
Log --> Controller : ok
deactivate Log

Controller --> UI : confirmacao
deactivate Controller
UI --> Admin : exibirSucesso()
deactivate UI

@enduml

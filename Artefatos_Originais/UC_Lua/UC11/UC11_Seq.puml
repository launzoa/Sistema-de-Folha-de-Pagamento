@startuml
title Sequência - UC-11: Fechar Folha de Pagamento

actor "Operador" as Operador
participant ":TelaProcessamento" as UI
participant ":FolhaController" as Controller
participant "fp:FolhaPagamento" as Folha
participant "LogAuditoria" as Log

Operador -> UI : fecharFolha(mes)
activate UI
UI -> Controller : fecharFolha(mes)
activate Controller

Controller -> Folha : setStatus("Fechada")
activate Folha
Folha --> Controller : ok
deactivate Folha

Controller -> Log : registrar(usuario, data, "Fechar Folha")
activate Log
Log --> Controller : ok
deactivate Log

Controller --> UI : confirmacao
deactivate Controller
UI --> Operador : exibirSucesso()
deactivate UI

@enduml
